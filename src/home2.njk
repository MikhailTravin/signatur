<body class="preload mp">
    <div class="main-wrapper-outer">
        {% include 'blocks/header.njk' %}
        <main class="main">

            <div class="block-intro block-intro-home2">
                <div class="block-intro__content">
                    <div class="block-intro__slider swiper">
                        <div class="block-intro__wrapper swiper-wrapper">
                            <div class="block-intro__slide swiper-slide">
                                <img src="img/image41.webp" alt="">
                                <div class="container2">
                                    <div class="block-intro__item">
                                        <div class="block-intro__top">
                                            <h2 class="title2">
                                                Свой дом.
                                                <br>
                                                Со всеми преимуществами города
                                            </h2>
                                            <div class="block-intro__title text">
                                                Индивидуальные дома в квартале «Сигнатур» — это центральные
                                                коммуникации, продуманная инфраструктура и архитектура в едином
                                                европейском стиле.
                                                Здесь начинается жизнь, которую вы выбираете
                                            </div>
                                        </div>
                                        <div class="block-intro__center">
                                            <div class="block-intro__buttons">
                                                <a href="#" class="btn mini">
                                                    <span>Смотреть дома и участки</span>
                                                    <svg aria-hidden="true" width="12" height="8">
                                                        <use xlink:href="img/sprite.svg#arrow1"></use>
                                                    </svg>
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="block-intro__arrows">
                        <div class="block-intro__arrow-prev arrow-prev">
                            <svg aria-hidden="true" width="12" height="8">
                                <use xlink:href="img/sprite.svg#arrow1"></use>
                            </svg>
                        </div>
                        <div class="block-intro__arrow-next arrow-next">
                            <svg aria-hidden="true" width="12" height="8">
                                <use xlink:href="img/sprite.svg#arrow1"></use>
                            </svg>
                        </div>
                    </div>
                </div>
            </div>

            <div class="block-benefits">
                <div class="container">
                    <div class="block-benefits__content">
                        <h2 class="title2">
                            Мы перенесли стандарты городского комфорта на землю
                        </h2>
                        <div class="block-benefits__body">
                            <div class="block-benefits__column">
                                <div class="block-benefits__icon">
                                    <svg aria-hidden="true" width="18" height="22">
                                        <use xlink:href="img/sprite.svg#icon1"></use>
                                    </svg>
                                </div>
                                <div class="block-benefits__item">
                                    <div class="block-benefits__title">
                                        Центральные коммуникации
                                    </div>
                                    <div class="block-benefits__subtitle">
                                        Вода, канализация и газ — городские. Никаких септиков и скважин
                                    </div>
                                </div>
                            </div>
                            <div class="block-benefits__column">
                                <div class="block-benefits__icon">
                                    <img src="img/icons/icon2.svg" alt="">
                                </div>
                                <div class="block-benefits__item">
                                    <div class="block-benefits__title">
                                        Архитектура ансамбля
                                    </div>
                                    <div class="block-benefits__subtitle">
                                        Дома объединены общим стилем, но у каждого свой фасад. Квартал выглядит цельным
                                        и живым
                                    </div>
                                </div>
                            </div>
                            <div class="block-benefits__column">
                                <div class="block-benefits__icon">
                                    <svg aria-hidden="true" width="24" height="24">
                                        <use xlink:href="img/sprite.svg#icon3"></use>
                                    </svg>
                                </div>
                                <div class="block-benefits__item">
                                    <div class="block-benefits__title">
                                        Готовый участок
                                    </div>
                                    <div class="block-benefits__subtitle">
                                        Выравнивание, газон, подъездные пути и ливневка — всё подготовлено, чтобы жить с
                                        первого дня
                                    </div>
                                </div>
                            </div>
                            <div class="block-benefits__column">
                                <div class="block-benefits__icon">
                                    <svg aria-hidden="true" width="24" height="24">
                                        <use xlink:href="img/sprite.svg#icon4"></use>
                                    </svg>
                                </div>
                                <div class="block-benefits__item">
                                    <div class="block-benefits__title">
                                        Выбор планировки
                                    </div>
                                    <div class="block-benefits__subtitle">
                                        От компактных «двушек» до просторных семейных домов. Можем обсудить и
                                        индивидуальный проект
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            {% include 'blocks/genplan.njk' %}

            <div class="block-house-about1">
                <div class="container">
                    <div class="block-house-about1__content">
                        <div class="block-house-about1__body">
                            <div class="block-house-about1__titles">
                                <h2 class="title2">
                                    Мы строим основательно, как строили здесь всегда
                                </h2>
                                <p>
                                    Городская вода и канализация
                                    в частном доме — это не роскошь, а стандарт «Сигнатур»
                                </p>
                            </div>
                            <div class="block-house-about1__text">
                                Никаких забот <span>о септиках</span>
                            </div>
                        </div>
                        <div data-da=".block-house-about1__body, 768, 1" class="block-house-about1__images">
                            <img src="img/image42.webp" alt="">
                            <div class="block-house-about1__title">
                                Только чистый комфорт городской квартиры, который остаётся с вами за вашим собственным
                                забором
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="block-house-descr">
                <img src="img/image43.webp" alt="" class="block-house-descr__bg1">
                <div class="container">
                    <div class="block-house-descr__content">
                        <h2 class="title2">Дом и участок — всё, что важно знать</h2>
                        <div class="block-house-descr__body">
                            <div class="block-house-descr__left">
                                <div class="block-house-descr__title">
                                    Коммуникации<br> на участке
                                </div>
                                <ul>
                                    <li>Центральные вода, канализация и газ подведены к каждому дому</li>
                                    <li>Ливневка и дренаж тоже централизованные — после дождя во дворе сухо</li>
                                    <li>Возможность поставить баню или хозяйственную постройку</li>
                                    <li>Предусмотрено место под парковку с навесом</li>
                                </ul>
                            </div>
                            <div class="block-house-descr__right">
                                <div class="block-house-descr__titles">
                                    <div class="block-house-descr__icons">
                                        <div class="block-house-descr__icon">
                                            <img src="img/icons/bicycle.svg" alt="">
                                        </div>
                                    </div>
                                    <div class="block-house-descr__name">
                                        Участок готов к вашей жизни
                                    </div>
                                </div>
                                <p>
                                    Когда вы получаете ключи, участок уже выровнен, засеян газон, сделан подъезд к дому
                                    и дорожка из тротуарной плитки от ворот
                                    до крыльца. По периметру стоит ограждение, можно сразу поставить откатные ворота с
                                    электроприводом
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="block-house">
                <div class="container">
                    <div class="block-house__content">
                        <div class="block-house__body">
                            <div class="block-house__column">
                                <h2 class="title2">
                                    Дом собран основательно
                                </h2>
                                <a data-da=".block-house__content, 768, last" href="#" class="btn btn-bg">
                                    <span>Смотреть дома и участки</span>
                                    <svg aria-hidden="true" width="12" height="8">
                                        <use xlink:href="img/sprite.svg#arrow1"></use>
                                    </svg>
                                </a>
                            </div>
                            <div class="block-house__column">
                                <img src="img/image44.webp" alt="">
                                <div class="block-house__text">
                                    <div class="block-house__title">Стены</div>
                                    <p>
                                        Керамический кирпич или керамический камень. Утепление 50 мм
                                        пенополистирола,
                                        сверху декоративная штукатурка. Керамика дышит, не боится сырости, не
                                        пропускает
                                        шум
                                    </p>
                                </div>
                            </div>
                            <div class="block-house__column">
                                <img src="img/image45.webp" alt="">
                                <div class="block-house__text">
                                    <div class="block-house__title">Отделка</div>
                                    <p>
                                        Дом передаётся в состоянии «серый ключ»: стены оштукатурены, полы со стяжкой.
                                        Финишную отделку делаете сами
                                    </p>
                                </div>
                            </div>
                            <div class="block-house__column">
                                <img src="img/image46.webp" alt="">
                                <div class="block-house__text">
                                    <div class="block-house__title">Кровля</div>
                                    <p>
                                        Двускатная, покрыта керамической черепицей
                                    </p>
                                </div>
                            </div>
                            <div class="block-house__column">
                                <img src="img/image47.webp" alt="">
                                <div class="block-house__text">
                                    <div class="block-house__title">Потолки</div>
                                    <p>
                                        Высота три метра. В кухне-гостиной можно сделать второй свет — тогда высота
                                        доходит до 5,5 метров
                                    </p>
                                </div>
                            </div>
                            <div class="block-house__column">
                                <img src="img/image48.webp" alt="">
                                <div class="block-house__text">
                                    <div class="block-house__title">Окна и двери</div>
                                    <p>
                                        Пластиковые стеклопакеты, распашные двери на террасу. Входная дверь
                                        металлическая
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="block-engineering-systems">
                <img src="img/image50.webp" alt="" class="block-engineering-systems__bg1">
                <div class="container">
                    <div class="block-engineering-systems__content">
                        <div class="block-engineering-systems__top">
                            <h2 class="title2">Инженерные<br> системы</h2>
                            <div data-da=".block-engineering-systems__content, 768,last"
                                class="block-engineering-systems__descr">
                                <div class="block-engineering-systems__title">
                                    Всё, что отвечает за тепло, свет
                                    и воду
                                </div>
                                <div class="block-engineering-systems__text">
                                    <p>
                                        Мы спроектировали инженерные системы так, чтобы вы чувствовали себя
                                        в доме так же комфортно, как в современной городской квартире.
                                    </p>
                                    <p>
                                        Только теперь это ваш собственное пространство
                                    </p>
                                </div>
                            </div>
                        </div>
